{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voquill Installer",
  "version": "0.1.0",
  "identifier": "com.voquill.installer",
  "build": {
    "beforeDevCommand": "vite",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Voquill Installer",
        "width": 480,
        "height": 320,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "center": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
