{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/en/:path*",
        "destination": "/:path*",
        "type": 301
      },
      {
        "source": "/en",
        "destination": "/",
        "type": 301
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "index,follow"
          }
        ]
      }
    ],
    "cleanUrls": true
  }
}
