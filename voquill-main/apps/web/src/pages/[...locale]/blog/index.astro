---
import Header from '../../../components/Header.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import { defaultLocale, type Locale } from '../../../types/locale';
import { t } from '../../../i18n/translations';
import Layout from '../../../layouts/Layout.astro';
import { formatBlogDate, getAllBlogPosts } from '../../../lib/blog';
import {
	buildBreadcrumbStructuredData,
	toAbsoluteUrl,
} from '../../../utils/seo';
import { localePath } from '../../../utils/paths';
export { getLocaleStaticPaths as getStaticPaths } from '../../../utils/paths';

const locale = (Astro.params.locale ?? defaultLocale) as Locale;
const i18n = t(locale);
const posts = getAllBlogPosts();
const pageTitle =
	locale === 'en'
		? 'Voquill Blog | Private Dictation, Voice Typing, and Local AI'
		: `${i18n.blogTitle} | Voquill`;
const pageDescription =
	locale === 'en'
		? 'Guides on private dictation, local speech-to-text, on-prem deployment, and AI-assisted writing workflows.'
		: i18n.blogSubtitle;
const structuredData = [
	buildBreadcrumbStructuredData([
		{ name: i18n.blogHome, item: toAbsoluteUrl(localePath(locale, '/')) },
		{ name: i18n.blogTitle, item: toAbsoluteUrl(localePath(locale, '/blog')) },
	]),
];
---

<Layout
	title={pageTitle}
	description={pageDescription}
	lang={locale}
	structuredData={structuredData}
>
	<Header locale={locale} />
	<main class="blog-main">
		<header class="blog-header">
			<h1 class="blog-title">{i18n.blogTitle}</h1>
			<p class="blog-subtitle">{i18n.blogSubtitle}</p>
		</header>
		<div class="blog-grid">
			{posts.map((post) => (
				<a href={localePath(locale, `/blog/${post.slug}`)} class="blog-card">
					{post.image && (
						<div class="card-image-wrapper">
							<img src={post.image} alt={post.title} class="card-image" width="680" height="383" loading="lazy" decoding="async" />
						</div>
					)}
					<div class="card-body">
						<div class="card-meta">
							<time datetime={post.date}>{formatBlogDate(post.date)}</time>
							<span class="card-meta-separator" />
							<span>{post.author}</span>
						</div>
						<h2 class="card-title">{post.title}</h2>
						<p class="card-description">{post.description}</p>
						<div class="card-tags">
							{post.tags.map((tag) => (
								<span class="card-tag">{tag}</span>
							))}
						</div>
						<span class="read-more">{i18n.blogReadArticle}</span>
					</div>
				</a>
			))}
		</div>
	</main>
	<SiteFooter locale={locale} />
</Layout>

<style>
	.blog-main {
		width: min(1120px, 100%);
		margin: 0 auto;
		padding: 0 24px 120px;
	}

	.blog-header {
		margin-bottom: 48px;
	}

	.blog-title {
		font-size: clamp(2.2rem, 4vw, 3rem);
		letter-spacing: -0.03em;
		margin-bottom: 12px;
	}

	.blog-subtitle {
		font-size: 1.1rem;
		opacity: 0.6;
		max-width: 520px;
	}

	.blog-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
		gap: 32px;
	}

	.blog-card {
		display: flex;
		flex-direction: column;
		gap: 16px;
		border-radius: 20px;
		background: var(--level1);
		border: 1px solid var(--border);
		transition: transform 0.2s ease, box-shadow 0.2s ease;
		text-decoration: none;
		color: inherit;
		overflow: hidden;
	}

	.blog-card:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-soft);
	}

	.card-image-wrapper {
		width: 100%;
		aspect-ratio: 16 / 9;
		overflow: hidden;
	}

	.card-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s ease;
	}

	.blog-card:hover .card-image {
		transform: scale(1.03);
	}

	.card-body {
		display: flex;
		flex-direction: column;
		gap: 16px;
		padding: 0 32px 32px;
		flex: 1;
	}

	.card-meta {
		display: flex;
		align-items: center;
		gap: 12px;
		font-size: 0.85rem;
		opacity: 0.5;
	}

	.card-meta-separator {
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: currentColor;
		opacity: 0.5;
	}

	.card-title {
		font-size: 1.35rem;
		font-weight: 600;
		letter-spacing: -0.02em;
		line-height: 1.35;
	}

	.card-description {
		font-size: 0.95rem;
		line-height: 1.6;
		opacity: 0.7;
	}

	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-top: auto;
	}

	.card-tag {
		font-size: 0.78rem;
		font-weight: 500;
		padding: 4px 12px;
		border-radius: 999px;
		background: var(--level2);
		opacity: 0.7;
	}

	.read-more {
		font-size: 0.9rem;
		font-weight: 600;
		opacity: 0.7;
		transition: opacity 0.2s ease;
	}

	.blog-card:hover .read-more {
		opacity: 1;
	}

	@media (max-width: 600px) {
		.blog-grid {
			grid-template-columns: 1fr;
		}

		.blog-card {
			gap: 10px;
		}

		.card-body {
			padding: 0 16px 16px;
		}
	}
</style>
