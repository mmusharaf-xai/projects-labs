---
import LegalLayout from '../../layouts/LegalLayout.astro';
import { renderLocalizedMarkdownFile } from '../../lib/markdown';
import { defaultLocale, type Locale } from '../../types/locale';
export { getLocaleStaticPaths as getStaticPaths } from '../../utils/paths';

const locale = (Astro.params.locale ?? defaultLocale) as Locale;
const html = await renderLocalizedMarkdownFile('content/contact.md', locale);
---

<LegalLayout title="Contact | Voquill" description="Get in touch with the Voquill team for support, enterprise inquiries, or general questions." locale={locale}>
	<Fragment set:html={html} />
</LegalLayout>
