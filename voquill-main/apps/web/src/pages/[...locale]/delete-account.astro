---
import LegalLayout from '../../layouts/LegalLayout.astro';
import { renderLocalizedMarkdownFile } from '../../lib/markdown';
import { defaultLocale, type Locale } from '../../types/locale';
export { getLocaleStaticPaths as getStaticPaths } from '../../utils/paths';

const locale = (Astro.params.locale ?? defaultLocale) as Locale;
const html = await renderLocalizedMarkdownFile(
	'content/delete-account.md',
	locale,
);
---

<LegalLayout
	title="Delete Account | Voquill"
	description="Learn how to delete your Voquill account."
	locale={locale}
	robots="noindex, nofollow, noarchive"
>
	<Fragment set:html={html} />
</LegalLayout>
