---
import type { Locale } from '../types/locale';
import { t } from '../i18n/translations';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const i18n = t(locale);
---

<section class="offline-section" id="offline">
	<div class="offline-content">
		<span class="badge">{i18n.offlineBadge}</span>
		<h2>{i18n.offlineHeading}</h2>
		<p>{i18n.offlineDescription}</p>
	</div>
	<div class="offline-media" aria-hidden="true">
		<div class="offline-wrapper">
			<div class="icon-container">
				<svg viewBox="0 0 160 160" class="wifi-svg" fill="none">
					<defs>
						<linearGradient id="arcGradient" x1="0%" y1="0%" x2="100%" y2="100%">
							<stop offset="0%" class="arc-light" />
							<stop offset="50%" class="arc-mid" />
							<stop offset="100%" class="arc-dark" />
						</linearGradient>
						<radialGradient id="dotGradient" cx="30%" cy="30%" r="70%">
							<stop offset="0%" class="dot-light" />
							<stop offset="100%" class="dot-dark" />
						</radialGradient>
						<linearGradient id="arcHighlight" x1="0%" y1="0%" x2="0%" y2="100%">
							<stop offset="0%" stop-color="white" stop-opacity="0.3" />
							<stop offset="100%" stop-color="white" stop-opacity="0" />
						</linearGradient>
					</defs>

					<!-- Outer arc shadow -->
					<path d="M25 85 A75 75 0 0 1 135 85" stroke="black" stroke-opacity="0.12" stroke-width="14" stroke-linecap="round" fill="none" transform="translate(2, 3)" />
					<!-- Outer arc -->
					<path d="M25 85 A75 75 0 0 1 135 85" stroke="url(#arcGradient)" stroke-width="12" stroke-linecap="round" fill="none" />
					<!-- Outer arc highlight -->
					<path d="M29 82 A71 71 0 0 1 131 82" stroke="white" stroke-opacity="0.2" stroke-width="2" stroke-linecap="round" fill="none" />

					<!-- Middle arc shadow -->
					<path d="M45 100 A50 50 0 0 1 115 100" stroke="black" stroke-opacity="0.12" stroke-width="14" stroke-linecap="round" fill="none" transform="translate(2, 3)" />
					<!-- Middle arc -->
					<path d="M45 100 A50 50 0 0 1 115 100" stroke="url(#arcGradient)" stroke-width="12" stroke-linecap="round" fill="none" />
					<!-- Middle arc highlight -->
					<path d="M49 97 A46 46 0 0 1 111 97" stroke="white" stroke-opacity="0.2" stroke-width="2" stroke-linecap="round" fill="none" />

					<!-- Inner arc shadow -->
					<path d="M60 115 A28 28 0 0 1 100 115" stroke="black" stroke-opacity="0.12" stroke-width="14" stroke-linecap="round" fill="none" transform="translate(2, 3)" />
					<!-- Inner arc -->
					<path d="M60 115 A28 28 0 0 1 100 115" stroke="url(#arcGradient)" stroke-width="12" stroke-linecap="round" fill="none" />
					<!-- Inner arc highlight -->
					<path d="M64 112 A24 24 0 0 1 96 112" stroke="white" stroke-opacity="0.2" stroke-width="2" stroke-linecap="round" fill="none" />

					<!-- Center dot shadow -->
					<circle cx="82" cy="138" r="10" fill="black" fill-opacity="0.15" />
					<!-- Center dot -->
					<circle cx="80" cy="136" r="10" fill="url(#dotGradient)" />
					<!-- Dot highlight -->
					<circle cx="77" cy="133" r="3" fill="white" fill-opacity="0.3" />

					<!-- Strike-through background knockout -->
					<line x1="22" y1="145" x2="138" y2="22" class="strike-knockout" stroke-width="20" stroke-linecap="round" />
					<!-- Strike-through shadow -->
					<line x1="22" y1="145" x2="138" y2="22" stroke="black" stroke-opacity="0.12" stroke-width="14" stroke-linecap="round" transform="translate(2, 2)" />
					<!-- Strike-through line -->
					<line x1="22" y1="145" x2="138" y2="22" stroke="url(#arcGradient)" stroke-width="12" stroke-linecap="round" />
					<!-- Strike highlight -->
					<line x1="26" y1="141" x2="134" y2="26" stroke="white" stroke-opacity="0.2" stroke-width="2" stroke-linecap="round" />
				</svg>
			</div>
			<span class="sr-only">{i18n.offlineIconAlt}</span>
		</div>
	</div>
</section>

<style>
	.offline-section {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 56px;
		align-items: center;
		max-width: min(1120px, 100%);
		margin: 120px auto 0;
	}

	.offline-content {
		display: flex;
		flex-direction: column;
		gap: 18px;
		max-width: 58ch;
	}

	.offline-content h2 {
		font-size: clamp(1.8rem, 2.5vw, 2.2rem);
		line-height: 1.2;
		letter-spacing: -0.02em;
	}

	.offline-content p {
		font-size: 1.05rem;
		line-height: 1.75;
		color: var(--text-muted);
	}

	.badge {
		align-self: flex-start;
		padding: 6px 18px;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: var(--level1);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-strong);
	}

	@media (prefers-color-scheme: dark) {
		.badge {
			background: rgba(255, 255, 255, 0.12);
			border-color: rgba(255, 255, 255, 0.24);
			color: rgba(255, 255, 255, 0.92);
		}
	}

	.offline-media {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 420px;
	}

	.offline-wrapper {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		height: 100%;
		min-height: 280px;
	}

	.icon-container {
		position: relative;
		animation: float 6s ease-in-out infinite;
		filter: drop-shadow(0 24px 48px rgba(0, 0, 0, 0.2));
	}

	@media (prefers-color-scheme: dark) {
		.icon-container {
			filter: drop-shadow(0 24px 48px rgba(0, 0, 0, 0.5));
		}
	}

	.wifi-svg {
		width: 180px;
		height: 180px;
	}

	/* Arc gradient stops */
	.arc-light {
		stop-color: #5c6370;
	}
	.arc-mid {
		stop-color: #3a3f4a;
	}
	.arc-dark {
		stop-color: #1e2128;
	}

	/* Strike knockout - matches page background */
	.strike-knockout {
		stroke: #ffffff;
	}

	@media (prefers-color-scheme: dark) {
		.strike-knockout {
			stroke: #121212;
		}
	}

	/* Dot gradient stops */
	.dot-light {
		stop-color: #484d58;
	}
	.dot-dark {
		stop-color: #1a1d22;
	}

	@media (prefers-color-scheme: dark) {
		.arc-light {
			stop-color: #f5f7fb;
		}
		.arc-mid {
			stop-color: #d8dce6;
		}
		.arc-dark {
			stop-color: #c0c5d0;
		}
		.dot-light {
			stop-color: #f8f9fc;
		}
		.dot-dark {
			stop-color: #d0d4de;
		}
	}

	.sr-only {
		border: 0;
		clip: rect(0 0 0 0);
		height: 1px;
		margin: -1px;
		overflow: hidden;
		padding: 0;
		position: absolute;
		width: 1px;
	}

	@keyframes float {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-12px);
		}
	}

	@media (max-width: 960px) {
		.offline-section {
			grid-template-columns: 1fr;
		}

		.offline-media {
			min-height: 360px;
		}
	}

	@media (max-width: 720px) {
		.wifi-svg {
			width: 150px;
			height: 150px;
		}
	}

	@media (max-width: 520px) {
		.offline-media {
			min-height: 300px;
		}
	}
</style>
