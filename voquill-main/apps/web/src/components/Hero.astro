---
import type { Locale } from '../types/locale';
import { t } from '../i18n/translations';
import { localePath } from '../utils/paths';
import DownloadButton from './DownloadButton.astro';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const i18n = t(locale);
---

<section class="hero" id="overview">
	<div class="hero-content">
		<h1>{i18n.heroHeading}</h1>
		<p class="hero-subtitle">
			{i18n.heroSubtitle}
		</p>
		<div class="hero-actions">
			<DownloadButton class="btn-primary" label={i18n.downloadForFree} locale={locale} />
			<a
				href="https://github.com/voquill/voquill"
				target="_blank"
				rel="noopener noreferrer"
				class="btn-secondary"
				data-track="GitHub"
				><span class="github-icon" aria-hidden="true"></span>{i18n.openSource}</a
			>
		</div>
		<div class="hero-meta">
			<p class="hero-note">{i18n.freeToUse}</p>
			<div class="hero-platform-list" aria-label="Desktop downloads">
				<span
					class="hero-platform-badge"
					role="img"
					aria-label="macOS"
					title="macOS"
				>
					<span
						class="hero-platform-icon"
						style="mask-image: url(/apple.svg); -webkit-mask-image: url(/apple.svg);"
					></span>
				</span>
				<span
					class="hero-platform-badge"
					role="img"
					aria-label="Windows"
					title="Windows"
				>
					<span
						class="hero-platform-icon"
						style="mask-image: url(/windows.svg); -webkit-mask-image: url(/windows.svg);"
					></span>
				</span>
				<span
					class="hero-platform-badge"
					role="img"
					aria-label="Linux"
					title="Linux"
				>
					<span
						class="hero-platform-icon"
						style="mask-image: url(/ubuntu.svg); -webkit-mask-image: url(/ubuntu.svg);"
					></span>
				</span>
				<span
					class="hero-platform-text"
					title="iOS"
				>iOS</span>
				<span
					class="hero-platform-badge"
					role="img"
					aria-label="Android"
					title="Android"
				>
					<span
						class="hero-platform-icon"
						style="mask-image: url(/android.svg); -webkit-mask-image: url(/android.svg);"
					></span>
				</span>
			</div>
			<a href={localePath(locale, '/download')} class="hero-more-link">{i18n.moreDownloads}</a>
			<a
				href="https://www.producthunt.com/products/voquill?embed=true&utm_source=badge-featured&utm_medium=badge&utm_campaign=badge-voquill-2"
				target="_blank"
				rel="noopener noreferrer"
				class="product-hunt-badge"
			>
				<img
					src="https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=1061874&theme=dark"
					alt={i18n.productHuntAlt}
					width="250"
					height="54"
				/>
			</a>
		</div>
	</div>
	<div class="hero-graphic" aria-hidden="true"></div>
</section>

<style>
	.hero {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 64px;
		align-items: center;
		min-height: calc(100vh - 280px);
		width: min(1120px, 100%);
		margin: 0 auto;
	}

	.hero-content {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		text-align: left;
		gap: 24px;
	}

	.hero h1 {
		font-size: clamp(2.5rem, 4vw, 3.5rem);
		line-height: 1.05;
		letter-spacing: -0.035em;
	}

	.hero-subtitle {
		font-size: 1.05rem;
		line-height: 1.7;
		color: var(--text-strong);
		max-width: 72ch;
	}

	.hero-actions {
		display: flex;
		align-items: center;
		gap: 16px;
		flex-wrap: wrap;
	}

	.hero-meta {
		display: flex;
		flex-direction: column;
		gap: 12px;
		align-items: flex-start;
	}

	.hero-note {
		font-size: 0.95rem;
		color: var(--text-muted);
		margin-top: 8px;
	}

	.hero-platform-list {
		display: flex;
		align-items: center;
		justify-content: flex-start;
		gap: 14px;
		flex-wrap: wrap;
	}

	.hero-platform-badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--text-muted);
	}

	.hero-platform-text {
		font-size: 0.95rem;
		font-weight: 700;
		color: var(--text-muted);
		letter-spacing: -0.02em;
	}

	.hero-platform-icon {
		display: inline-block;
		width: 24px;
		height: 24px;
		background-color: currentColor;
		mask-size: contain;
		mask-repeat: no-repeat;
		mask-position: center;
		-webkit-mask-size: contain;
		-webkit-mask-repeat: no-repeat;
		-webkit-mask-position: center;
		color: var(--text-muted);
	}

	.product-hunt-badge img {
		margin-top: 16px;
		display: block;
	}

	.hero-more-link {
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--text-muted);
		text-decoration: underline;
		text-decoration-thickness: 2px;
		text-underline-offset: 4px;
	}

	.hero-graphic {
		position: relative;
		width: 100%;
		min-height: 400px;
		overflow: visible;
	}

	:global(.hero-svg) {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 200vw;
		height: 200vh;
		pointer-events: none;
	}

	:global(.hero-wave-path) {
		stroke: rgba(0, 0, 0, 1);
		stroke-width: 3;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	:global(.hero-path-text) {
		font-size: 14px;
		font-weight: 500;
		font-family: system-ui, -apple-system, sans-serif;
		fill: rgba(0, 0, 0, 0.7);
	}

	:global(.hero-icon-glow) {
		fill: rgba(0, 0, 0, 0.04);
		filter: blur(8px);
	}

	:global(.hero-icon-circle) {
		fill: #111111;
	}

	:global(.hero-icon-logo) {
		filter: invert(1);
	}

	:global(.hero-spark) {
		fill: rgba(0, 0, 0, 0.6);
	}

	@media (prefers-color-scheme: dark) {
		:global(.hero-wave-path) {
			stroke: rgba(255, 255, 255, 1);
		}

		:global(.hero-path-text) {
			fill: rgba(255, 255, 255, 0.7);
		}

		:global(.hero-icon-glow) {
			fill: rgba(255, 255, 255, 0.08);
		}

		:global(.hero-icon-circle) {
			fill: #ffffff;
		}

		:global(.hero-icon-logo) {
			filter: none;
		}

		:global(.hero-spark) {
			fill: rgba(255, 255, 255, 0.6);
		}
	}

	@media (max-width: 960px) {
		.hero {
			grid-template-columns: 1fr;
			min-height: auto;
			padding: 20px 0;
		}

		.hero-content {
			align-items: center;
			text-align: center;
		}

		.hero-actions {
			justify-content: center;
		}

		.hero-meta {
			align-items: center;
		}

		.hero-platform-list {
			justify-content: center;
		}

		.hero-graphic {
			display: none;
		}
	}

	@media (max-width: 520px) {
		.hero h1 {
			font-size: clamp(2.2rem, 8vw, 2.8rem);
		}

		.hero-platform-icon {
			width: 22px;
			height: 22px;
		}
	}
</style>
