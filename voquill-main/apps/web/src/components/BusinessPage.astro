		margin-bottom: 0.4rem;
	}

	.biz-benefit-card p {
		color: var(--text-muted);
		font-size: 0.9rem;
		line-height: 1.65;
	}

	/* ── Enterprise Features ── */
	.biz-enterprise {
		background: var(--level1);
		padding: 5rem 2rem;
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
		margin-left: -24px;
		margin-right: -24px;
	}

	.biz-enterprise-inner {
		max-width: 800px;
		margin: 0 auto;
	}

	.biz-enterprise h2 {
		font-weight: 700;
		font-size: clamp(1.5rem, 3.5vw, 2rem);
		line-height: 1.25;
		letter-spacing: -0.025em;
		margin-bottom: 0.75rem;
	}

	.biz-enterprise-lead {
		color: var(--text-muted);
		font-size: 1rem;
		line-height: 1.7;
		max-width: 600px;
		margin-bottom: 2.5rem;
	}

	.biz-features-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
	}

	.biz-feature-card {
		background: var(--level0);
		border-radius: 12px;
		padding: 2rem;
		border: 1px solid var(--border);
	}

	.biz-feature-icon {
		margin-right: 0.4rem;
	}

	.biz-feature-card h3 {
		font-weight: 600;
		font-size: 1rem;
		margin-bottom: 0.5rem;
	}

	.biz-feature-card p {
		color: var(--text-muted);
		font-size: 0.9rem;
		line-height: 1.65;
	}

	/* ── AI Multiplier ── */
	.biz-multiplier {
		max-width: 780px;
		margin: 0 auto;
		padding: 5rem 2rem;
	}

	.biz-multiplier h2 {
		font-weight: 700;
		font-size: clamp(1.5rem, 3.5vw, 2rem);
		line-height: 1.25;
		letter-spacing: -0.025em;
		margin-bottom: 1.5rem;
	}

	.biz-multiplier > p {
		color: var(--text-muted);
		font-size: 1rem;
		line-height: 1.75;
		margin-bottom: 1.25rem;
		max-width: 680px;
	}

	.biz-stats {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
		margin: 2rem 0 0.5rem;
	}

	.biz-stat {
		border-left: 2px solid var(--text-strong);
		padding: 0.5rem 0 0.5rem 1.25rem;
	}

