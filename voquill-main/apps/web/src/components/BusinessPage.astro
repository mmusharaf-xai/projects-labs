	}

	@media (prefers-color-scheme: dark) {
		.biz-cta-btn {
			background: var(--primary-button-bg);
			color: var(--primary-button-fg);
		}
	}

	.biz-cta-note {
		margin-top: 1rem;
		font-size: 0.8rem;
		color: rgba(255, 255, 255, 0.3);
	}

	@media (prefers-color-scheme: dark) {
		.biz-cta-note {
			color: var(--text-muted);
			opacity: 0.5;
		}
	}

	/* ── Responsive ── */
	@media (max-width: 720px) {
		.biz-hero {
			padding: 4rem 1.5rem 3rem;
		}

		.biz-steps {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.biz-benefits-grid {
			grid-template-columns: 1fr;
		}

		.biz-features-grid {
			grid-template-columns: 1fr;
		}

		.biz-stats {
			grid-template-columns: 1fr;
			gap: 1rem;
		}

		.biz-table {
			font-size: 0.85rem;
		}

		.biz-table th,
		.biz-table td {
			padding: 0.7rem 0.8rem;
		}

		.biz-how,
		.biz-enterprise,
		.biz-trust,
		.biz-cta {
			margin-left: -18px;
			margin-right: -18px;
		}
	}
</style>
