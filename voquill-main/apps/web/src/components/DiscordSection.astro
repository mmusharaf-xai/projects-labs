---
import type { Locale } from '../types/locale';
import { t } from '../i18n/translations';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const i18n = t(locale);
---

<section class="discord-section" id="community">
	<div class="discord-card">
		<div class="discord-bg-orbs" aria-hidden="true">
			<span class="orb orb-1"></span>
			<span class="orb orb-2"></span>
			<span class="orb orb-3"></span>
			<span class="orb orb-4"></span>
			<span class="orb orb-5"></span>
			<span class="orb orb-6"></span>
			<span class="orb orb-7"></span>
			<span class="orb orb-8"></span>
		</div>
		<div class="discord-content">
			<div class="badges">
				<span class="badge new-badge">{i18n.discordNewBadge}</span>
				<span class="badge online-badge" data-discord-online style="display:none">
					<span class="ping-wrapper">
						<span class="ping"></span>
						<span class="ping-dot"></span>
					</span>
					<span data-discord-count></span>
				</span>
			</div>
			<h2>{i18n.discordHeading}</h2>
			<p>{i18n.discordDescription}</p>
			<a
				href="https://discord.gg/5jXkDvdVdt"
				target="_blank"
				rel="noopener noreferrer"
				class="discord-button"
				data-track="Discord"
			>
				<span class="discord-button-icon" aria-hidden="true"></span>
				{i18n.discordJoin}
			</a>
		</div>
	</div>
</section>

<script>
	(function () {
		var INVITE_CODE = '5jXkDvdVdt';
		var TEN_MINUTES = 10 * 60 * 1000;

		var badgeEl = document.querySelector('[data-discord-online]') as HTMLElement | null;
		var countEl = document.querySelector('[data-discord-count]');
		if (!badgeEl || !countEl) return;

		function fetchCount() {
			fetch('https://discord.com/api/v9/invites/' + INVITE_CODE + '?with_counts=true')
				.then(function (r) { return r.ok ? r.json() : null; })
				.then(function (data) {
					if (data && data.approximate_presence_count) {
						countEl!.textContent = data.approximate_presence_count.toLocaleString() + ' Online';
						badgeEl!.style.display = '';
					}
				})
				.catch(function () {});
		}

		fetchCount();
		setInterval(fetchCount, TEN_MINUTES);
	})();
</script>

<style>
	.discord-section {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		max-width: min(1120px, 100%);
		margin: 120px auto 0;
		padding: 0 24px;
	}

	.discord-card {
		position: relative;
		width: 100%;
		border-radius: 32px;
		background: linear-gradient(145deg, rgba(88, 101, 242, 0.08) 0%, rgba(88, 101, 242, 0.03) 50%, rgba(88, 101, 242, 0.06) 100%);
		border: 1px solid rgba(88, 101, 242, 0.15);
		box-shadow:
			0 4px 24px rgba(88, 101, 242, 0.06),
			0 0 0 1px rgba(88, 101, 242, 0.04);
		padding: 64px 48px;
		overflow: hidden;
	}

	@media (prefers-color-scheme: dark) {
		.discord-card {
			background: linear-gradient(145deg, rgba(88, 101, 242, 0.12) 0%, rgba(88, 101, 242, 0.04) 50%, rgba(88, 101, 242, 0.08) 100%);
			border-color: rgba(88, 101, 242, 0.25);
			box-shadow:
				0 4px 32px rgba(88, 101, 242, 0.1),
				0 0 0 1px rgba(88, 101, 242, 0.08);
		}
	}

	/* Floating orbs */
	.discord-bg-orbs {
		position: absolute;
		inset: 0;
		pointer-events: none;
	}

	.orb {
		position: absolute;
		border-radius: 50%;
		background: rgba(88, 101, 242, 0.12);
		border: 1px solid rgba(88, 101, 242, 0.1);
	}

	@media (prefers-color-scheme: dark) {
		.orb {
			background: rgba(88, 101, 242, 0.18);
			border-color: rgba(88, 101, 242, 0.15);
		}
	}

	.orb-1 {
		width: 48px;
		height: 48px;
		top: 12%;
		left: 8%;
		animation: float-1 8s ease-in-out infinite;
	}

	.orb-2 {
		width: 32px;
		height: 32px;
		top: 24%;
		right: 12%;
		animation: float-2 10s ease-in-out infinite;
	}

	.orb-3 {
		width: 40px;
		height: 40px;
		bottom: 18%;
		left: 14%;
		animation: float-3 9s ease-in-out infinite;
	}

	.orb-4 {
		width: 24px;
		height: 24px;
		bottom: 28%;
		right: 8%;
		animation: float-1 7s ease-in-out infinite 1s;
	}

	.orb-5 {
		width: 20px;
		height: 20px;
		top: 50%;
		left: 4%;
		animation: float-2 11s ease-in-out infinite 0.5s;
	}

	.orb-6 {
		width: 36px;
		height: 36px;
		top: 8%;
		right: 28%;
		animation: float-3 8.5s ease-in-out infinite 2s;
	}

	.orb-7 {
		width: 28px;
		height: 28px;
		bottom: 10%;
		right: 24%;
		animation: float-1 9.5s ease-in-out infinite 1.5s;
	}

	.orb-8 {
		width: 18px;
		height: 18px;
		top: 36%;
		left: 24%;
		animation: float-2 7.5s ease-in-out infinite 3s;
	}

	@keyframes float-1 {
		0%, 100% { transform: translate(0, 0); }
		25% { transform: translate(12px, -18px); }
		50% { transform: translate(-8px, -28px); }
		75% { transform: translate(16px, -10px); }
	}

	@keyframes float-2 {
		0%, 100% { transform: translate(0, 0); }
		25% { transform: translate(-14px, 12px); }
		50% { transform: translate(10px, 20px); }
		75% { transform: translate(-18px, 6px); }
	}

	@keyframes float-3 {
		0%, 100% { transform: translate(0, 0); }
		33% { transform: translate(16px, -14px); }
		66% { transform: translate(-12px, 10px); }
	}

	.discord-content {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 18px;
		max-width: 560px;
		margin: 0 auto;
	}

	.discord-content h2 {
		font-size: clamp(1.8rem, 2.5vw, 2.2rem);
		line-height: 1.2;
		letter-spacing: -0.02em;
	}

	.discord-content p {
		font-size: 1.05rem;
		line-height: 1.75;
		color: var(--text-muted);
	}

	.badges {
		display: flex;
		align-items: center;
		gap: 10px;
	}

	.badge {
		padding: 6px 18px;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: var(--level1);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-strong);
	}

	@media (prefers-color-scheme: dark) {
		.badge {
			background: rgba(255, 255, 255, 0.12);
			border-color: rgba(255, 255, 255, 0.24);
			color: rgba(255, 255, 255, 0.92);
		}
	}

	.new-badge {
		background: linear-gradient(135deg, #f97316 0%, #ef4444 100%);
		color: white;
		border-color: transparent;
	}

	.online-badge {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		text-transform: none;
		letter-spacing: normal;
	}

	.ping-wrapper {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 10px;
		height: 10px;
	}

	.ping {
		position: absolute;
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background-color: #22c55e;
		animation: ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;
	}

	.ping-dot {
		position: relative;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background-color: #22c55e;
	}

	@keyframes ping {
		0% {
			transform: scale(1);
			opacity: 1;
		}
		75%,
		100% {
			transform: scale(2);
			opacity: 0;
		}
	}

	.discord-button {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 12px 22px;
		border-radius: 999px;
		background: #5865f2;
		color: white;
		font-size: 0.95rem;
		font-weight: 600;
		border: 1px solid rgba(0, 0, 0, 0.1);
		box-shadow: 0 4px 16px rgba(88, 101, 242, 0.3);
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease,
			background-color 0.2s ease;
		margin-top: 8px;
	}

	.discord-button:hover {
		background: #4752c4;
		box-shadow: 0 6px 24px rgba(88, 101, 242, 0.4);
		transform: translateY(-2px);
	}

	.discord-button:active {
		transform: translateY(0);
		box-shadow: 0 2px 8px rgba(88, 101, 242, 0.3);
	}

	.discord-button-icon {
		display: inline-block;
		width: 20px;
		height: 20px;
		background-color: white;
		mask: url('/discord.svg') center/contain no-repeat;
		-webkit-mask: url('/discord.svg') center/contain no-repeat;
		flex-shrink: 0;
	}

	@media (max-width: 720px) {
		.discord-card {
			padding: 48px 24px;
		}

		.orb-5,
		.orb-8 {
			display: none;
		}
	}
</style>
