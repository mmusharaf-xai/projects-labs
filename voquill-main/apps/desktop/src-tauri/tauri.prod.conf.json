{
  "productName": "Voquill",
  "identifier": "com.voquill.desktop",
  "mainBinaryName": "Voquill",
  "bundle": {
    "linux": {
      "deb": {
        "depends": ["libxdo3", "xdotool", "libvulkan1", "libgtk-layer-shell0", "wtype"],
        "conflicts": ["voquill-gpu"],
        "replaces": ["voquill-gpu"]
      },
      "rpm": {
        "depends": ["xdotool", "vulkan-loader", "gtk-layer-shell", "wtype"],
        "conflicts": ["voquill-gpu"],
        "obsoletes": ["voquill-gpu"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/voquill/voquill/releases/download/desktop-prod/latest.json"
      ]
    }
  }
}
