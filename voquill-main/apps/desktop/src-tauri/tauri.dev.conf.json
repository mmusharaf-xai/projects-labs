{
  "productName": "Voquill (dev)",
  "identifier": "com.voquill.desktop.dev",
  "mainBinaryName": "Voquill (dev)",
  "bundle": {
    "linux": {
      "deb": {
        "conflicts": ["voquill-gpu-dev"],
        "replaces": ["voquill-gpu-dev"]
      },
      "rpm": {
        "conflicts": ["voquill-gpu-dev"],
        "obsoletes": ["voquill-gpu-dev"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/voquill/voquill/releases/download/desktop-dev/latest.json"
      ]
    }
  }
}
