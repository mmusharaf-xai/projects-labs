{
  "name": "desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prepare:sidecars": "node scripts/prepare-sidecars.mjs",
    "dev": "node scripts/select-platform-dev.mjs",
    "dev:mac": "cross-env TAURI_PLATFORM=macos pnpm run dev:tauri",
    "dev:windows": "cross-env TAURI_PLATFORM=windows pnpm run dev:tauri",
    "dev:linux": "cross-env TAURI_PLATFORM=linux pnpm run dev:tauri",
    "dev:tauri": "pnpm run prepare:sidecars && node -e \"const c=process.env.TAURI_DEV_CONFIG||'src-tauri/tauri.local.conf.json';require('child_process').execSync('pnpm tauri dev --config '+c,{stdio:'inherit'})\"",
    "dev:vite": "node scripts/run-vite-with-flavor.mjs dev",
    "build": "tsc && node scripts/run-vite-with-flavor.mjs build",
    "preview": "node scripts/run-vite-with-flavor.mjs preview",
    "tauri": "node scripts/run-tauri-with-sidecars.mjs",
    "test:webdriver": "wdio run webdriver/wdio.conf.js",
    "i18n:extract": "node ./scripts/i18n-extract-with-prune.mjs",
    "i18n:sync": "node ./scripts/i18n-sync.mjs",
    "i18n": "pnpm run i18n:extract && pnpm run i18n:sync",
    "lint:fix": "prettier --write src && oxlint --fix src",
    "lint": "prettier --check src && oxlint src",
    "test": "vitest run",
    "test:unit": "vitest run src",
    "test:integration": "vitest run test/integration",
    "test:evals": "vitest run test/evals"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@mui/icons-material": "^7.3.9",
    "@mui/lab": "7.0.0-beta.17",
    "@mui/material": "^7.3.9",
    "@mui/system": "^7.3.9",
    "@repo/agent": "workspace:*",
    "@stripe/react-stripe-js": "^3.10.0",
    "@stripe/stripe-js": "^7.9.0",
    "@tauri-apps/api": "~2.10.1",
    "@tauri-apps/plugin-autostart": "~2.5.1",
    "@tauri-apps/plugin-http": "~2.5.8",
    "@tauri-apps/plugin-log": "~2.8.0",
    "@tauri-apps/plugin-opener": "~2.5.3",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-sql": "~2.4.0",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "@voquill/functions": "workspace:*",
    "@voquill/pricing": "workspace:*",
    "@voquill/types": "workspace:*",
    "@voquill/utilities": "workspace:*",
    "@voquill/voice-ai": "workspace:*",
    "chroma-js": "^3.2.0",
    "dayjs": "^1.11.20",
    "firebase": "^11.10.0",
    "framer-motion": "^12.38.0",
    "immer": "^10.2.0",
    "lodash-es": "^4.18.1",
    "mixpanel-browser": "^2.77.0",
    "react": "^19.2.4",
    "react-confetti": "^6.4.0",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-intl": "^7.1.14",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.3",
    "react-transition-group": "^4.4.5",
    "react-virtuoso": "^4.18.4",
    "remark-gfm": "^4.0.1",
    "rxjs": "^7.8.2",
    "vite-plugin-svgr": "^4.5.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@formatjs/cli": "^6.14.1",
    "@tauri-apps/cli": "~2.10.1",
    "@types/chroma-js": "^3.1.2",
    "@types/lodash-es": "^4.17.12",
    "@types/mixpanel-browser": "^2.66.0",
    "@types/react": "19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/react-transition-group": "^4.4.12",
    "@vitejs/plugin-react": "^4.7.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "babel-plugin-formatjs": "^10.5.41",
    "chromedriver": "^141.0.6",
    "cross-env": "^7.0.3",
    "dotenv": "^16.6.1",
    "oxlint": "^1.59.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.3",
    "vite": "^7.3.2",
    "vitest": "^3.2.4"
  }
}
