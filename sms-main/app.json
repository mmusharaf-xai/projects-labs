{
  "expo": {
    "name": "SchoolManagementSystem",
    "slug": "school-management-system",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app uses the microphone for voice-to-text input in forms."
      }
    },
    "android": {
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {},
    "scheme": "school-management-system",
    "plugins": [
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      "expo-asset",
      [
        "expo-av",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone for voice input."
        }
      ]
    ]
  }
}
